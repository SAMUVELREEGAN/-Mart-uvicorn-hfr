{
  "productCard": {
    "layout": "vertical",
    "fields": ["name", "price", "rating"],
    "pricePrefix": "$",
    "imageAspectRatio": "1 / 1",
    "compact": true
  },
  "serviceCard": {
    "layout": "horizontal",
    "fields": ["name", "rating", "category", "city", "price", "description"],
    "descriptionMaxLength": 90,
    "imageWidth": "224px",
    "imageWidthMobile": "136px",
    "imageAspectRatio": "4 / 3",
    "pricePrefix": "$",
    "categoryIcon": "FaTag",
    "locationIcon": "FaMapMarkerAlt",
    "actions": {
      "primary": { "label": "View Details", "icon": "FaArrowRight" },
      "secondary": { "label": "Book Now", "icon": "FaCalendarCheck" }
    },
    "grid": {
      "desktopColumns": 2,
      "tabletColumns": 2,
      "mobileColumns": 1
    }
  },
  "highlightCard": {
    "layout": "overlay",
    "fields": ["title"]
  },
  "consultantCard": {
    "layout": "profile",
    "fields": ["image", "name", "company", "experience", "rating", "city", "contact"]
  },
  "categoryItem": {
    "layout": "icon-label",
    "fields": ["icon", "name"]
  },
  "carousels": {
    "products": {
      "carousel": true,
      "responsiveOnly": true,
      "breakpoint": 992,
      "snap": true,
      "hideScrollbar": true,
      "autoScroll": false
    },
    "services": {
      "carousel": false
    },
    "brands": {
      "carousel": true,
      "autoScroll": true,
      "infinite": true,
      "pauseOnHover": true,
      "speed": 24,
      "hideScrollbar": true,
      "logoSize": 88
    },
    "highlights": {
      "carousel": true,
      "responsiveOnly": true,
      "breakpoint": 768,
      "snap": true,
      "hideScrollbar": true,
      "mobileReducedSize": true
    },
    "consultants": {
      "carousel": true,
      "responsiveOnly": true,
      "breakpoint": 992,
      "snap": true,
      "hideScrollbar": true
    },
    "categories": {
      "carousel": false
    },
    "subcategories": {
      "carousel": true,
      "responsiveOnly": false,
      "snap": true,
      "hideScrollbar": true
    },
    "reviews": {
      "carousel": true,
      "responsiveOnly": true,
      "breakpoint": 992,
      "snap": true,
      "hideScrollbar": true
    },
    "vendors": {
      "carousel": true,
      "responsiveOnly": true,
      "breakpoint": 768,
      "snap": true,
      "hideScrollbar": true
    }
  },
  "emptyState": {
    "products": { "icon": "FaBoxOpen", "title": "No Products Found", "message": "Try adjusting your search or browse categories" },
    "services": { "icon": "FaConciergeBell", "title": "No Services Found", "message": "Try adjusting your search or browse service categories" },
    "reviews": { "icon": "FaCommentSlash", "title": "No Reviews Yet", "message": "Be the first to leave a review" },
    "orders": { "icon": "FaShoppingBag", "title": "No Orders Yet", "message": "Your order history will appear here" },
    "wishlist": { "icon": "FaHeart", "title": "Wishlist Empty", "message": "Save items you love to your wishlist" },
    "brands": { "icon": "FaStore", "title": "No Items for This Brand", "message": "This brand has no listed products or services yet" }
  },
  "errorState": {
    "default": { "icon": "FaExclamationTriangle", "title": "Something went wrong", "message": "Please try again later" },
    "notFound": { "icon": "FaSearch", "title": "Page Not Found", "message": "The page you're looking for doesn't exist" }
  },
  "searchPage": {
    "relatedServicesTitle": "Related Services",
    "closePanelAriaLabel": "Close services panel",
    "closePanelIcon": "FaTimes",
    "servicesPanelMaxItems": 4
  }
}
